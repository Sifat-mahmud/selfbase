# .env.example
# Copy to .env — this file is generated automatically by install.sh
# Never commit .env to git.

NODE_ENV=production
DOMAIN=localhost

# Admin (set via install.sh or manually)
ADMIN_EMAIL=admin@selfbase.local
ADMIN_PASS=changeme123

# Auth secrets (generated by install.sh — do not share)
JWT_SECRET=replace_with_32_byte_hex
ENCRYPTION_KEY=replace_with_32_byte_hex

# Postgres
POSTGRES_USER=selfbase
POSTGRES_PASS=replace_with_secure_password
POSTGRES_DB=selfbase
DATABASE_URL=postgresql://selfbase:replace_with_secure_password@postgres:5432/selfbase

# Redis
REDIS_URL=redis://redis:6379

# MinIO
MINIO_ROOT_USER=selfbase
MINIO_ROOT_PASSWORD=replace_with_secure_password
STORAGE_URL=http://minio:9000
STORAGE_BUCKET=selfbase

# Ports
GATEWAY_PORT=3000
STUDIO_PORT=4000
REALTIME_PORT=3001
AUTH_PORT=3002
STORAGE_PORT=3003
FUNCTIONS_PORT=3004
AI_PORT=3005
MONITOR_PORT=3006
